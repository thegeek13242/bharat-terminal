# ──────────────────────────────────────────────────────────────
# Bharat Terminal — Environment Configuration
# Copy to .env and fill in your values before running.
# ──────────────────────────────────────────────────────────────

# REQUIRED ─────────────────────────────────────────────────────
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# OPTIONAL — defaults work for local docker-compose ────────────

# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# PostgreSQL (pgvector)
DATABASE_URL=postgresql+asyncpg://bharat:bharat@postgres:5432/bharat_terminal

# Redis
REDIS_URL=redis://redis:6379/0

# Knowledge Base service (internal)
KB_SERVICE_URL=http://kb-service:8001

# LLM model selection
# Available: claude-haiku-4-5-20251001 (fast/cheap), claude-sonnet-4-6 (better quality)
EXTRACTION_MODEL=claude-haiku-4-5-20251001
IMPACT_MODEL=claude-haiku-4-5-20251001
SIGNALS_MODEL=claude-haiku-4-5-20251001

# Analysis tuning
RELEVANCE_THRESHOLD=0.35        # 0.0–1.0: lower = more news passes through
LLM_LOG_FILE=/tmp/llm_calls.jsonl
